{
    "name": "phpfiletool/filetool",
    "description": "A PHP library for file and directory management.",
    "type": "library",
    "homepage": "https://github.com/AntonioCarioca/PHP-FileTool",
    "license": "GPL-3.0-or-later",
    "authors": [
        {
            "name": "Antonio Silva",
            "email": "antoniomarcos.silva@protonmail.com",
            "homepage": "https://antoniosilva.hashnode.dev/",
            "role": "Developer"
        }
    ],
    "autoload": {
        "psr-4": {
            "PHPFileTool\\FileTool\\": "src/"
        }
    },
    "require": {
        "php": "^8.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.1",
        "phpstan/phpstan": "^2.1",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse src tests",
        "cs": "phpcs src tests",
        "cs:fix": "phpcbf src tests"
    },
    "minimum-stability": "stable"
}